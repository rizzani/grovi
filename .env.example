# Appwrite Configuration
# Copy this file to .env and fill in your Appwrite credentials

# Appwrite Endpoint (e.g., https://cloud.appwrite.io/v1 or your self-hosted URL)
EXPO_PUBLIC_APPWRITE_ENDPOINT=

# Appwrite Project ID (found in your Appwrite project settings)
EXPO_PUBLIC_APPWRITE_PROJECT_ID=

# Platform identifier (e.g., "com.grovi.app" for production)
EXPO_PUBLIC_APPWRITE_PLATFORM=

# OAuth Redirect URL
# For Expo dev: exp://localhost:8081
# For EAS production: your-app-scheme:// (e.g., grovi://)
EXPO_PUBLIC_OAUTH_REDIRECT_URL=

